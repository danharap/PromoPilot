# ============================================================
# PromoPilot Environment Variables
# ============================================================
# Copy to .env.local for local dev. Never commit .env.local.
# ============================================================

# --- Frontend (CRA — bundled into the browser) ---
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here

# --- Server only (Vercel dashboard + vercel dev for api/*) ---
SUPABASE_SERVICE_ROLE_KEY=your_service_role_or_sb_secret_key_here

# Mastodon OAuth callback — must match your deployed URL exactly
MASTODON_CALLBACK_URL=https://promo-pilot-five.vercel.app/api/mastodon/oauth-callback

# Protects GET /api/cron/publish-scheduled — generate: openssl rand -hex 32
# Use the same value in Vercel and in cron-job.org as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
